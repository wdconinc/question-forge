# Required
API_TOKEN=changeme8          # 8-char alphanumeric token; share with browser users
LITELLM_MODEL=gpt-4o         # Any LiteLLM model string, e.g.:
                             #   gpt-4o  |  claude-3-5-sonnet-20241022  |  gemini/gemini-2.5-flash  |  ollama/llama3

# Provider API keys (only the one matching your model is needed)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional
PORT=8000
